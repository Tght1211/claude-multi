# Provider: DashScope / Alibaba Cloud (Anthropic-compatible endpoint)
# Copy to dashscope.env and fill in your DashScope API key.
# Docs: https://help.aliyun.com/zh/model-studio
export ANTHROPIC_AUTH_TOKEN="sk-YOUR_DASHSCOPE_KEY_HERE"
export ANTHROPIC_BASE_URL="https://dashscope.aliyuncs.com/apps/anthropic"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="qwen-turbo"
export ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME="qwen-turbo"
export ANTHROPIC_DEFAULT_OPUS_MODEL="qwen-max"
export ANTHROPIC_DEFAULT_OPUS_MODEL_NAME="qwen-max"
export ANTHROPIC_DEFAULT_SONNET_MODEL="qwen-plus"
export ANTHROPIC_DEFAULT_SONNET_MODEL_NAME="qwen-plus"
export ANTHROPIC_MODEL="qwen-plus"
