# Provider: DashScope / 阿里云百炼 (Anthropic 兼容端点)
# 复制为 dashscope.env 并填入你的 DashScope API Key。
# 模型广场: https://bailian.console.aliyun.com/?tab=model
# 文档: https://help.aliyun.com/zh/model-studio/getting-started/models
export ANTHROPIC_AUTH_TOKEN="sk-YOUR_DASHSCOPE_KEY_HERE"
export ANTHROPIC_BASE_URL="https://dashscope.aliyuncs.com/apps/anthropic"
# qwen3.7-max (旗舰) → Opus, qwen3.6-plus (均衡) → Sonnet, qwen3.6-flash (轻量) → Haiku
export ANTHROPIC_DEFAULT_HAIKU_MODEL="qwen3.6-flash"
export ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME="qwen3.6-flash"
export ANTHROPIC_DEFAULT_OPUS_MODEL="qwen3.7-max"
export ANTHROPIC_DEFAULT_OPUS_MODEL_NAME="qwen3.7-max"
export ANTHROPIC_DEFAULT_SONNET_MODEL="qwen3.6-plus"
export ANTHROPIC_DEFAULT_SONNET_MODEL_NAME="qwen3.6-plus"
export ANTHROPIC_MODEL="qwen3.6-plus"
