# Provider: qwen (Alibaba DashScope, Anthropic-compatible endpoint)
# Copy to qwen.env and fill in your DashScope API key.
export ANTHROPIC_AUTH_TOKEN="sk-YOUR_DASHSCOPE_KEY_HERE"
export ANTHROPIC_BASE_URL="https://dashscope.aliyuncs.com/apps/anthropic"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="qwen-latest-series-invite-beta-v34"
export ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME="qwen-latest-series-invite-beta-v34"
export ANTHROPIC_DEFAULT_OPUS_MODEL="qwen-latest-series-invite-beta-v34[1M]"
export ANTHROPIC_DEFAULT_OPUS_MODEL_NAME="qwen-latest-series-invite-beta-v34"
export ANTHROPIC_DEFAULT_SONNET_MODEL="qwen-latest-series-invite-beta-v34"
export ANTHROPIC_DEFAULT_SONNET_MODEL_NAME="qwen-latest-series-invite-beta-v34"
export ANTHROPIC_MODEL="qwen-latest-series-invite-beta-v34"
export CLAUDE_CODE_SUBAGENT_MODEL="qwen-latest-series-invite-beta-v23"
