# Provider: Generic third-party Anthropic-compatible API
# Use this template for any provider that implements the Anthropic Messages API.
# Copy to <provider-name>.env and fill in the values.
#
# Required: the provider must support POST /v1/messages with Anthropic's
# request/response format (including streaming SSE and tool_use).
export ANTHROPIC_AUTH_TOKEN="YOUR_API_KEY_HERE"
export ANTHROPIC_BASE_URL="https://your-provider.example.com"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="your-model-small"
export ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME="your-model-small"
export ANTHROPIC_DEFAULT_OPUS_MODEL="your-model-large"
export ANTHROPIC_DEFAULT_OPUS_MODEL_NAME="your-model-large"
export ANTHROPIC_DEFAULT_SONNET_MODEL="your-model-medium"
export ANTHROPIC_DEFAULT_SONNET_MODEL_NAME="your-model-medium"
export ANTHROPIC_MODEL="your-model-medium"
