# Provider: Kimi / Moonshot AI (Anthropic-compatible endpoint)
# Copy to kimi.env and fill in your Moonshot API key.
# Docs: https://platform.moonshot.cn/docs
export ANTHROPIC_AUTH_TOKEN="sk-YOUR_MOONSHOT_KEY_HERE"
export ANTHROPIC_BASE_URL="https://api.moonshot.cn/anthropic"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="moonshot-v1-8k"
export ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME="moonshot-v1-8k"
export ANTHROPIC_DEFAULT_OPUS_MODEL="moonshot-v1-128k"
export ANTHROPIC_DEFAULT_OPUS_MODEL_NAME="moonshot-v1-128k"
export ANTHROPIC_DEFAULT_SONNET_MODEL="moonshot-v1-32k"
export ANTHROPIC_DEFAULT_SONNET_MODEL_NAME="moonshot-v1-32k"
export ANTHROPIC_MODEL="moonshot-v1-32k"
