# Provider: DeepSeek (Anthropic-compatible endpoint)
# Copy to deepseek.env and fill in your DeepSeek API key.
# Docs: https://api-docs.deepseek.com
export ANTHROPIC_AUTH_TOKEN="sk-YOUR_DEEPSEEK_KEY_HERE"
export ANTHROPIC_BASE_URL="https://api.deepseek.com/anthropic"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="deepseek-chat"
export ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME="deepseek-chat"
export ANTHROPIC_DEFAULT_OPUS_MODEL="deepseek-chat"
export ANTHROPIC_DEFAULT_OPUS_MODEL_NAME="deepseek-chat"
export ANTHROPIC_DEFAULT_SONNET_MODEL="deepseek-chat"
export ANTHROPIC_DEFAULT_SONNET_MODEL_NAME="deepseek-chat"
export ANTHROPIC_MODEL="deepseek-chat"
