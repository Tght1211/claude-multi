# Provider: MiniMax (Anthropic-compatible endpoint)
# Copy to minimax.env and fill in your MiniMax API key.
# Docs: https://platform.minimaxi.com/docs
export ANTHROPIC_AUTH_TOKEN="YOUR_MINIMAX_KEY_HERE"
export ANTHROPIC_BASE_URL="https://api.minimax.chat/anthropic"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="abab5.5-chat"
export ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME="abab5.5-chat"
export ANTHROPIC_DEFAULT_OPUS_MODEL="abab6.5-chat"
export ANTHROPIC_DEFAULT_OPUS_MODEL_NAME="abab6.5-chat"
export ANTHROPIC_DEFAULT_SONNET_MODEL="abab6.5-chat"
export ANTHROPIC_DEFAULT_SONNET_MODEL_NAME="abab6.5-chat"
export ANTHROPIC_MODEL="abab6.5-chat"
