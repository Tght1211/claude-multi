# Provider: OpenRouter (multi-model aggregator, Anthropic-compatible endpoint)
# Copy to openrouter.env and fill in your OpenRouter API key.
# Docs: https://openrouter.ai/docs
export ANTHROPIC_AUTH_TOKEN="sk-or-v1-YOUR_OPENROUTER_KEY_HERE"
export ANTHROPIC_BASE_URL="https://openrouter.ai/api/anthropic"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="anthropic/claude-haiku-4.5"
export ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME="claude-haiku-4-5-20251001"
export ANTHROPIC_DEFAULT_OPUS_MODEL="anthropic/claude-opus-4.7"
export ANTHROPIC_DEFAULT_OPUS_MODEL_NAME="claude-opus-4-7-20250514"
export ANTHROPIC_DEFAULT_SONNET_MODEL="anthropic/claude-sonnet-4.6"
export ANTHROPIC_DEFAULT_SONNET_MODEL_NAME="claude-sonnet-4-20250514"
export ANTHROPIC_MODEL="anthropic/claude-sonnet-4.6"
