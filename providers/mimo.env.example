# Provider: MIMO / Xiaomi (official Anthropic-compatible endpoint)
# Copy to mimo.env and fill in your MIMO API key.
# Docs: https://xiaomimimo.com
export ANTHROPIC_AUTH_TOKEN="YOUR_MIMO_KEY_HERE"
export ANTHROPIC_BASE_URL="https://token-plan-cn.xiaomimimo.com/anthropic"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="mimo-v2.5-pro"
export ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME="mimo-v2.5-pro"
export ANTHROPIC_DEFAULT_OPUS_MODEL="mimo-v2.5-pro"
export ANTHROPIC_DEFAULT_OPUS_MODEL_NAME="mimo-v2.5-pro"
export ANTHROPIC_DEFAULT_SONNET_MODEL="mimo-v2.5-pro"
export ANTHROPIC_DEFAULT_SONNET_MODEL_NAME="mimo-v2.5-pro"
export ANTHROPIC_MODEL="mimo-v2.5-pro"
